#!/usr/bin/env php
<?php

define('KYQO_START', microtime(true));
define('KYQO_ROOT', __DIR__);

/*
|--------------------------------------------------------------------------
| Kyqo CLI Entry Point
|--------------------------------------------------------------------------
|
| This script is the entry point for the Kyqo CLI (like Artisan in Laravel).
| It bootstraps the framework and runs the requested console command.
|
*/

if (file_exists(__DIR__.'/vendor/autoload.php')) {
    require __DIR__.'/vendor/autoload.php';
}

$app = require_once __DIR__.'/bootstrap/app.php';

$kernel = $app->make(Kyqo\Console\Kernel::class);

$status = $kernel->handle(
    $input = new Symfony\Component\Console\Input\ArgvInput,
    new Symfony\Component\Console\Output\ConsoleOutput
);

$kernel->terminate($input, $status);

exit($status);
