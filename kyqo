#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * Kyqo CLI entry point.
 *
 * FIX B3 – replaced non-existent Kyqo\Console\Input\ArgvInput and
 *           Kyqo\Console\Output\ConsoleOutput with the real Symfony classes
 *           that Console\Kernel already type-hints against.
 */

if (PHP_SAPI !== 'cli') {
    fwrite(STDERR, "This script must be run from the command line.\n");
    exit(1);
}

require __DIR__ . '/vendor/autoload.php';

$app = require __DIR__ . '/bootstrap/app.php';

$kernel = $app->make(\Kyqo\Console\Kernel::class);
$status = $kernel->handle(
    new \Symfony\Component\Console\Input\ArgvInput(),
    new \Symfony\Component\Console\Output\ConsoleOutput()
);

exit($status ?? 0);
