#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * Kyqo CLI entry point.
 *
 * Usage:
 *   php kyqo <command> [arguments] [--options]
 *
 * Examples:
 *   php kyqo migrate
 *   php kyqo migrate:rollback --step=2
 *   php kyqo queue:work --queue=default
 *   php kyqo make:controller UserController
 *   php kyqo make:model Post --migration
 *   php kyqo cache:clear
 *   php kyqo key:generate
 *   php kyqo serve --port=8000
 */

if (PHP_SAPI !== 'cli') {
    fwrite(STDERR, "This script must be run from the command line.\n");
    exit(1);
}

// ── Autoloader & Bootstrap ──────────────────────────────────────────────────
require __DIR__ . '/vendor/autoload.php';

$app = require __DIR__ . '/bootstrap/app.php';

// ── Run console kernel ──────────────────────────────────────────────────────
$kernel = $app->make(\Kyqo\Console\Kernel::class);
$status = $kernel->handle(
    new \Kyqo\Console\Input\ArgvInput($argv),
    new \Kyqo\Console\Output\ConsoleOutput()
);

exit($status ?? 0);
