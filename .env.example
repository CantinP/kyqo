# Kyqo Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to version control.

#---------------------------------------------------------------------------
# Application
#---------------------------------------------------------------------------
APP_NAME=Kyqo
APP_ENV=production
# SECURITY: Always set to false in production.
APP_DEBUG=false
APP_URL=http://localhost

# Generate with: php kyqo key:generate
# Must be a base64-encoded 32-byte key: base64:<64 hex chars>
APP_KEY=

#---------------------------------------------------------------------------
# Database
#---------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kyqo
DB_USERNAME=
DB_PASSWORD=

#---------------------------------------------------------------------------
# Session
#---------------------------------------------------------------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
# SECURITY: Always true in production (requires HTTPS).
SESSION_SECURE_COOKIE=true

#---------------------------------------------------------------------------
# Security
#---------------------------------------------------------------------------
# Comma-separated list of trusted reverse proxy IPs.
# Leave empty unless you are behind a load balancer.
TRUSTED_PROXIES=

# Max request body size in bytes (default 10MB)
MAX_BODY_SIZE=10485760

# Max file upload size in bytes (default 5MB)
MAX_UPLOAD_SIZE=5242880

# HSTS (HTTP Strict Transport Security)
HSTS_ENABLED=true

# Content Security Policy
CSP_ENABLED=true
CSP_REPORT_URI=

#---------------------------------------------------------------------------
# Cache
#---------------------------------------------------------------------------
CACHE_DRIVER=file

#---------------------------------------------------------------------------
# Queue
#---------------------------------------------------------------------------
QUEUE_CONNECTION=sync

#---------------------------------------------------------------------------
# Mail
#---------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@kyqo.dev
MAIL_FROM_NAME="${APP_NAME}"
