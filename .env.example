# Application
APP_NAME=Kyqo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kyqo
DB_USERNAME=root
DB_PASSWORD=

# Cache
CACHE_DRIVER=file
CACHE_PREFIX=kyqo_

# Session
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_COOKIE=kyqo_session
SESSION_SECURE=false
SESSION_SAMESITE=lax

# Queue
QUEUE_CONNECTION=sync
QUEUE_TABLE=jobs
QUEUE_FAILED_TABLE=failed_jobs

# Mail
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"

# Logging
LOG_CHANNEL=single
LOG_LEVEL=debug

# Auth
AUTH_GUARD=session
AUTH_PROVIDER=eloquent
AUTH_MODEL=App\Models\User
