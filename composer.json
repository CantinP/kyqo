{
    "name": "kyqo/kyqo",
    "description": "A powerful full-stack PHP + TypeScript framework — the only framework you'll ever need.",
    "keywords": ["framework", "php", "typescript", "full-stack", "kyqo"],
    "license": "MIT",
    "type": "project",
    "authors": [
        {
            "name": "Cantin Poiseau",
            "email": "cantin@kyqo.dev"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-pdo": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-json": "*",
        "symfony/console": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Kyqo\\": "packages/",
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "packages/core/src/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "kyqo": "php kyqo"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
